  "nodes": {
    "var_71a8495a3978": {
      "type": "variant",
      "label": "Midnight Logistics (Dashboard)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 0,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Source+Sans+3:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n    :root {\n        --bg-main: #07111F;\n        --bg-panel: #1E293B;\n        --accent-orange: #FF8C00;\n        --accent-green: #34D399;\n    }\n\n    .font-heading {\n        font-family: 'Manrope', sans-serif;\n    }\n\n    .font-body {\n        font-family: 'Source Sans 3', sans-serif;\n    }\n\n    .glass-panel {\n        background: rgba(30, 41, 59, 0.45);\n        backdrop-filter: blur(16px);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n    }\n\n    /* Active Nav Styling */\n    .active-nav-indicator {\n        position: absolute;\n        left: 0;\n        top: 20%;\n        bottom: 20%;\n        width: 4px;\n        background: var(--accent-orange);\n        border-radius: 0 6px 6px 0;\n        box-shadow: 6px 0 25px rgba(255, 140, 0, 0.4);\n    }\n\n    /* Pulse Glow */\n    @keyframes pulse-glow {\n        0%, 100% { box-shadow: 0 0 15px rgba(255, 140, 0, 0.2); }\n        50% { box-shadow: 0 0 35px rgba(255, 140, 0, 0.5); }\n    }\n    .btn-pulse {\n        animation: pulse-glow 3s infinite ease-in-out;\n    }\n\n    /* Scrollbar hide */\n    .no-scrollbar::-webkit-scrollbar { display: none; }\n    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n</style>\n\n<div class=\"flex bg-[#07111F] p-8 lg:p-12 gap-12 min-h-screen font-body text-[#E2E8F0] overflow-x-clip\" data-kid=\"1\">\n    \n    <aside class=\"sidebar-anim w-72 sticky top-12 h-[calc(100vh-96px)] glass-panel rounded-[2rem] flex flex-col z-50 overflow-hidden shadow-2xl border-white/5\" data-kid=\"2\">\n        <div class=\"p-8 pb-6\" data-kid=\"3\">\n            <div class=\"flex items-center gap-4\" data-kid=\"4\">\n                <div class=\"w-10 h-10 bg-[var(--accent-orange)] rounded-xl flex items-center justify-center text-white shadow-lg\" data-kid=\"5\">\n                    <i class=\"ti ti-heart-filled text-xl\" data-kid=\"6\"></i>\n                </div>\n                <div data-kid=\"7\">\n                    <h1 class=\"font-heading font-extrabold text-white text-lg tracking-tight\" data-kid=\"8\">BAMX Planner</h1>\n                    <p class=\"text-slate-500 text-[10px] font-bold uppercase tracking-widest opacity-60\" data-kid=\"9\">Logística Social</p>\n                </div>\n            </div>\n        </div>\n\n        <nav class=\"flex-1 px-4 mt-6 space-y-1 overflow-y-auto no-scrollbar\" data-kid=\"10\">\n            <a href=\"#\" class=\"relative group flex items-center gap-4 px-6 py-4 rounded-xl bg-white/10 text-white shadow-xl shadow-black/20\" data-kid=\"11\">\n                <div class=\"active-nav-indicator\" data-kid=\"12\"></div>\n                <i class=\"ti ti-layout-dashboard text-xl text-[var(--accent-orange)]\" data-kid=\"13\"></i>\n                <span class=\"font-bold text-sm tracking-wide\" data-kid=\"14\">Inicio</span>\n            </a>\n            <a href=\"#\" class=\"group flex items-center gap-4 px-6 py-4 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"15\">\n                <i class=\"ti ti-calendar-event text-xl group-hover:text-[var(--accent-orange)]\" data-kid=\"16\"></i>\n                <span class=\"font-bold text-sm\" data-kid=\"17\">Planeación</span>\n            </a>\n            <a href=\"#\" class=\"group flex items-center gap-4 px-6 py-4 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"18\">\n                <i class=\"ti ti-history text-xl group-hover:text-[var(--accent-orange)]\" data-kid=\"19\"></i>\n                <span class=\"font-bold text-sm\" data-kid=\"20\">Historial</span>\n            </a>\n\n            <div class=\"pt-8 pb-3 px-8\" data-kid=\"21\">\n                <span class=\"text-[10px] font-black text-slate-600 uppercase tracking-widest\" data-kid=\"22\">Recursos</span>\n            </div>\n\n            <a href=\"#\" class=\"group flex items-center gap-4 px-6 py-4 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"23\">\n                <i class=\"ti ti-map-pin text-xl group-hover:text-[var(--accent-orange)]\" data-kid=\"24\"></i>\n                <span class=\"font-bold text-sm\" data-kid=\"25\">Colonias</span>\n            </a>\n            <a href=\"#\" class=\"group flex items-center gap-4 px-6 py-4 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"26\">\n                <i class=\"ti ti-truck text-xl group-hover:text-[var(--accent-orange)]\" data-kid=\"27\"></i>\n                <span class=\"font-bold text-sm\" data-kid=\"28\">Unidades</span>\n            </a>\n            <a href=\"#\" class=\"group flex items-center gap-4 px-6 py-4 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"29\">\n                <i class=\"ti ti-users text-xl group-hover:text-[var(--accent-orange)]\" data-kid=\"30\"></i>\n                <span class=\"font-bold text-sm\" data-kid=\"31\">Choferes</span>\n            </a>\n        </nav>\n\n        <div class=\"p-6 mt-auto\" data-kid=\"32\">\n            <div class=\"bg-white/5 p-4 rounded-2xl border border-white/5 flex items-center gap-3\" data-kid=\"33\">\n                <img src=\"https://i.pravatar.cc/100?u=mid-log-admin\" class=\"w-10 h-10 rounded-lg object-cover\" alt=\"User\" data-kid=\"34\">\n                <div class=\"flex-1\" data-kid=\"35\">\n                    <p class=\"text-white text-xs font-bold leading-none\" data-kid=\"36\">Operación</p>\n                    <p class=\"text-slate-500 text-[10px] mt-1 font-medium\" data-kid=\"37\">Administrador</p>\n                </div>\n                <i class=\"ti ti-settings text-slate-500 hover:text-white cursor-pointer transition-colors\" data-kid=\"38\"></i>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 max-w-[1200px] space-y-12 pb-24\" data-kid=\"39\">\n        \n        <header class=\"header-anim flex flex-col xl:flex-row xl:items-end justify-between gap-12 glass-panel p-12 lg:p-16 rounded-[2.5rem] border-white/5\" data-kid=\"40\">\n            <div class=\"max-w-2xl\" data-kid=\"41\">\n                <p class=\"text-[var(--accent-orange)] font-bold text-sm mb-4 tracking-widest uppercase\" data-kid=\"42\">Panel de Operación</p>\n                <h2 class=\"text-5xl font-heading font-black text-white tracking-tighter leading-tight mb-6\" data-kid=\"43\">Gestiona la logística<br data-kid=\"44\">de impacto social.</h2>\n                <p class=\"text-slate-400 text-lg font-medium leading-relaxed opacity-80\" data-kid=\"45\">Sincroniza inventarios, optimiza rutas de entrega y monitorea la flota en tiempo real desde un solo centro de control.</p>\n            </div>\n            <div class=\"flex flex-wrap gap-4 shrink-0\" data-kid=\"46\">\n                <button class=\"btn-pulse px-8 py-4 bg-[var(--accent-orange)] text-white rounded-xl font-black text-base flex items-center gap-3 hover:scale-105 transition-transform duration-300 shadow-xl shadow-orange-950/20\" data-kid=\"47\">\n                    Generar planeación\n                    <i class=\"ti ti-arrow-narrow-right text-xl\" data-kid=\"48\"></i>\n                </button>\n                <button class=\"px-8 py-4 bg-white/5 border border-white/10 text-white rounded-xl font-bold text-base hover:bg-white/10 transition-colors\" data-kid=\"49\">\n                    Sincronizar Datos\n                </button>\n            </div>\n        </header>\n\n        \n        <section class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\" data-kid=\"50\">\n            <div class=\"kpi-anim\" data-kid=\"51\">\n                <div class=\"glass-panel p-8 rounded-[2rem] border-white/5 hover:border-white/20 transition-all duration-300 hover:-translate-y-2\" data-kid=\"52\">\n                    <div class=\"flex justify-between items-start mb-6\" data-kid=\"53\">\n                        <i class=\"ti ti-route text-2xl text-slate-500\" data-kid=\"54\"></i>\n                        <span class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"55\">Hoy</span>\n                    </div>\n                    <span class=\"text-5xl font-heading font-black text-white\" data-kid=\"56\">0</span>\n                    <p class=\"text-slate-500 text-sm font-bold mt-2 uppercase tracking-wide opacity-70\" data-kid=\"57\">Rutas activas</p>\n                </div>\n            </div>\n            <div class=\"kpi-anim\" data-kid=\"58\">\n                <div class=\"glass-panel p-8 rounded-[2rem] border-white/5 hover:border-white/20 transition-all duration-300 hover:-translate-y-2\" data-kid=\"59\">\n                    <div class=\"flex justify-between items-start mb-6\" data-kid=\"60\">\n                        <i class=\"ti ti-map-pins text-2xl text-slate-500\" data-kid=\"61\"></i>\n                        <span class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"62\">Total</span>\n                    </div>\n                    <span class=\"text-5xl font-heading font-black text-white\" data-kid=\"63\">67</span>\n                    <p class=\"text-slate-500 text-sm font-bold mt-2 uppercase tracking-wide opacity-70\" data-kid=\"64\">Puntos registrados</p>\n                </div>\n            </div>\n            <div class=\"kpi-anim\" data-kid=\"65\">\n                <div class=\"glass-panel p-8 rounded-[2rem] border-white/5 hover:border-white/20 transition-all duration-300 hover:-translate-y-2\" data-kid=\"66\">\n                    <div class=\"flex justify-between items-start mb-6\" data-kid=\"67\">\n                        <i class=\"ti ti-truck text-2xl text-emerald-400\" data-kid=\"68\"></i>\n                        <span class=\"text-[10px] font-bold text-emerald-500 uppercase tracking-widest\" data-kid=\"69\">Libre</span>\n                    </div>\n                    <span class=\"text-5xl font-heading font-black text-white\" data-kid=\"70\">2</span>\n                    <p class=\"text-slate-500 text-sm font-bold mt-2 uppercase tracking-wide opacity-70\" data-kid=\"71\">Unidades Disponibles</p>\n                </div>\n            </div>\n            <div class=\"kpi-anim\" data-kid=\"72\">\n                <div class=\"glass-panel p-8 rounded-[2rem] border-white/5 hover:border-white/20 transition-all duration-300 hover:-translate-y-2\" data-kid=\"73\">\n                    <div class=\"flex justify-between items-start mb-6\" data-kid=\"74\">\n                        <i class=\"ti ti-users text-2xl text-slate-500\" data-kid=\"75\"></i>\n                        <span class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"76\">Turno</span>\n                    </div>\n                    <span class=\"text-5xl font-heading font-black text-white\" data-kid=\"77\">2</span>\n                    <p class=\"text-slate-500 text-sm font-bold mt-2 uppercase tracking-wide opacity-70\" data-kid=\"78\">Choferes Activos</p>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"grid grid-cols-12 gap-10\" data-kid=\"79\">\n            \n            <div class=\"content-anim col-span-12 lg:col-span-8 space-y-8\" data-kid=\"80\">\n                <div class=\"px-2\" data-kid=\"81\">\n                    <h3 class=\"text-3xl font-heading font-extrabold text-white tracking-tight\" data-kid=\"82\">Trabajo pendiente</h3>\n                    <p class=\"text-slate-500 font-medium mt-1\" data-kid=\"83\">Sincronización de recursos requerida para hoy.</p>\n                </div>\n\n                <div class=\"glass-panel rounded-[2.5rem] overflow-hidden border-white/5 shadow-2xl\" data-kid=\"84\">\n                    <div class=\"divide-y divide-white/10\" data-kid=\"85\">\n                        <div class=\"group flex items-center gap-6 p-8 hover:bg-white/[0.04] transition-all duration-300 cursor-pointer\" data-kid=\"86\">\n                            <i class=\"ti ti-calendar-plus text-3xl text-[var(--accent-orange)] opacity-80 group-hover:scale-110 transition-transform\" data-kid=\"87\"></i>\n                            <div class=\"flex-1\" data-kid=\"88\">\n                                <h4 class=\"text-white font-bold text-lg mb-1\" data-kid=\"89\">Preparar planeación mensual</h4>\n                                <p class=\"text-slate-500 text-sm font-medium\" data-kid=\"90\">Revisión periódica de la red de distribución regional.</p>\n                            </div>\n                            <div class=\"px-4 py-2 bg-white/5 rounded-lg text-slate-500 text-xs font-bold uppercase tracking-widest\" data-kid=\"91\">Pendiente</div>\n                            <i class=\"ti ti-chevron-right text-slate-700 group-hover:text-white transition-colors ml-4\" data-kid=\"92\"></i>\n                        </div>\n                        <div class=\"group flex items-center gap-6 p-8 hover:bg-white/[0.03] transition-colors cursor-pointer\" data-kid=\"93\">\n                            <i class=\"ti ti-map-pin-filled text-3xl text-emerald-400 opacity-80 group-hover:scale-110 transition-transform\" data-kid=\"94\"></i>\n                            <div class=\"flex-1\" data-kid=\"95\">\n                                <h4 class=\"text-white font-bold text-lg mb-1\" data-kid=\"96\">Geolocalización y Ubicaciones</h4>\n                                <p class=\"text-slate-500 text-sm font-medium\" data-kid=\"97\">Sincronización de coordenadas con la base central.</p>\n                            </div>\n                            <div class=\"px-4 py-2 bg-emerald-500/10 rounded-lg text-emerald-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"98\">Actualizado</div>\n                            <i class=\"ti ti-chevron-right text-slate-700 group-hover:text-white transition-colors ml-4\" data-kid=\"99\"></i>\n                        </div>\n                        <div class=\"group flex items-center gap-6 p-8 hover:bg-white/[0.03] transition-colors cursor-pointer\" data-kid=\"100\">\n                            <i class=\"ti ti-steering-wheel text-3xl text-blue-400 opacity-80 group-hover:scale-110 transition-transform\" data-kid=\"101\"></i>\n                            <div class=\"flex-1\" data-kid=\"102\">\n                                <h4 class=\"text-white font-bold text-lg mb-1\" data-kid=\"103\">Flota y Choferes</h4>\n                                <p class=\"text-slate-500 text-sm font-medium\" data-kid=\"104\">Verificación de personal activo y estado de vehículos.</p>\n                            </div>\n                            <div class=\"px-4 py-2 bg-white/5 rounded-lg text-slate-500 text-xs font-bold uppercase tracking-widest\" data-kid=\"105\">Verificar</div>\n                            <i class=\"ti ti-chevron-right text-slate-700 group-hover:text-white transition-colors ml-4\" data-kid=\"106\"></i>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"content-anim col-span-12 lg:col-span-4 space-y-8\" data-kid=\"107\">\n                <div class=\"glass-panel p-12 rounded-[2.5rem] border-emerald-500/20 flex flex-col justify-between h-full min-h-[450px] shadow-2xl relative overflow-hidden\" data-kid=\"108\">\n                    <div class=\"absolute -top-12 -right-12 w-40 h-40 bg-emerald-500/5 blur-3xl\" data-kid=\"109\"></div>\n                    <div data-kid=\"110\">\n                        <div class=\"flex items-center gap-3 mb-8\" data-kid=\"111\">\n                            <div class=\"w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_#10B981]\" data-kid=\"112\"></div>\n                            <span class=\"text-emerald-500 font-black text-[10px] uppercase tracking-widest\" data-kid=\"113\">Sincronizado</span>\n                        </div>\n                        <h4 class=\"text-white font-black text-3xl tracking-tight mb-4\" data-kid=\"114\">Datos listos para operar</h4>\n                        <p class=\"text-slate-500 font-medium leading-relaxed opacity-80\" data-kid=\"115\">Todos los módulos críticos de la región metropolitana han sido validados exitosamente.</p>\n                    </div>\n                    \n                    <div class=\"space-y-6 pt-10 mt-auto border-t border-white/5\" data-kid=\"116\">\n                        <div class=\"flex items-center justify-between\" data-kid=\"117\">\n                            <span class=\"text-slate-500 text-xs font-bold uppercase tracking-widest\" data-kid=\"118\">Siguiente Ruta</span>\n                            <span class=\"px-3 py-1 bg-white/5 rounded-full text-[10px] font-black text-slate-400 uppercase\" data-kid=\"119\">Sin Programar</span>\n                        </div>\n                        <div class=\"p-6 bg-white/5 rounded-2xl border border-white/5 flex items-center gap-4 group cursor-pointer hover:bg-white/10 transition-colors\" data-kid=\"120\">\n                            <div class=\"w-12 h-12 bg-slate-800 rounded-xl flex items-center justify-center text-slate-400\" data-kid=\"121\">\n                                <i class=\"ti ti-download text-xl\" data-kid=\"122\"></i>\n                            </div>\n                            <div data-kid=\"123\">\n                                <p class=\"text-white text-sm font-bold\" data-kid=\"124\">Respaldo</p>\n                                <p class=\"text-slate-500 text-[10px] font-bold uppercase mt-1\" data-kid=\"125\">Recomendado</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <footer class=\"content-anim flex flex-col md:flex-row justify-between items-center gap-6 pt-12 border-t border-white/5\" data-kid=\"126\">\n            <p class=\"text-slate-700 text-[10px] font-black uppercase tracking-widest\" data-kid=\"127\">Midnight Logistics v2.5 • BAMX Planner</p>\n            <div class=\"flex gap-8\" data-kid=\"128\">\n                <a href=\"#\" class=\"text-slate-600 hover:text-white text-[10px] font-black uppercase tracking-widest transition-colors\" data-kid=\"129\">Soporte</a>\n                <a href=\"#\" class=\"text-slate-600 hover:text-white text-[10px] font-black uppercase tracking-widest transition-colors\" data-kid=\"130\">Seguridad</a>\n                <a href=\"#\" class=\"text-slate-600 hover:text-white text-[10px] font-black uppercase tracking-widest transition-colors\" data-kid=\"131\">Términos</a>\n            </div>\n        </footer>\n    </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"132\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"133\"></script>\n<script type=\"module\" data-kid=\"134\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    \n    const lenis = new Lenis({ lerp: 0.1, smoothWheel: true })\n    function raf(time) {\n        lenis.raf(time)\n        requestAnimationFrame(raf)\n    }\n    requestAnimationFrame(raf)\n    \n    gsap.registerPlugin(ScrollTrigger);\n\n    const tl = gsap.timeline({ defaults: { ease: \"power4.out\", duration: 1.2 } });\n    \n    tl.from(\".sidebar-anim\", { x: -80, autoAlpha: 0 })\n      .from(\".header-anim\", { y: 60, autoAlpha: 0 }, \"-=0.8\")\n      .from(\".kpi-anim\", { \n        y: 40, \n        autoAlpha: 0, \n        stagger: 0.1,\n        clearProps: \"all\"\n      }, \"-=0.6\")\n      .from(\".content-anim\", { \n        y: 40, \n        autoAlpha: 0, \n        stagger: 0.15,\n        clearProps: \"all\"\n      }, \"-=0.8\");\n\n</script>\n",
      "comments": [],
      "created": "2026-07-09T07:09:25.870775+00:00",
      "modified": "2026-07-09T07:09:25.870775+00:00",
