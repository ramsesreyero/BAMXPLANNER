      "overrides": {
        "htmlAttrs": " lang=\"es\"",
        "bodyAttrs": " class=\"min-h-screen\"",
        "head": "<meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Midnight Logistics Dashboard</title>"
      }
