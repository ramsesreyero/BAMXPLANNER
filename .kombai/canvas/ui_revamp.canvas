flex items-center justify-center rounded-none group-hover:bg-[#0F172A] group-hover:text-white transition-all\" data-kid=\"102\">\n                                    <i class=\"ph-bold ph-map-pin text-2xl\" data-kid=\"103\"></i>\n                                </div>\n                                <div data-kid=\"104\">\n                                    <h3 class=\"font-heading font-black text-xl text-[#0F172A] tracking-tighter uppercase\" data-kid=\"105\">Ubicaciones listas</h3>\n                                    <p class=\"text-[11px] text-[#0F172A]/60 mt-1 font-bold tracking-tight uppercase\" data-kid=\"106\">Georreferenciación completa de puntos.</p>\n                                </div>\n                            </div>\n                            <div class=\"flex items-center gap-12\" data-kid=\"107\">\n                                <div class=\"flex items-center gap-2 text-[#0F172A]\" data-kid=\"108\">\n                                    <i class=\"ph-fill ph-check-circle text-lg\" data-kid=\"109\"></i>\n                                    <span class=\"text-[10px] font-black uppercase tracking-[0.2em]\" data-kid=\"110\">SINCORNIZADO</span>\n                                </div>\n                                <i class=\"ph-bold ph-arrow-right text-[#0F172A]/20 group-hover:text-[#0F172A] transition-all group-hover:translate-x-2\" data-kid=\"111\"></i>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"py-8 border-b border-[#0F172A] flex items-center justify-between group cursor-pointer hover:bg-white transition-colors\" data-kid=\"112\">\n                            <div class=\"flex items-center gap-10\" data-kid=\"113\">\n                                <div class=\"w-14 h-14 border-2 border-[#0F172A] text-[#0F172A] flex items-center justify-center rounded-none group-hover:bg-[#0F172A] group-hover:text-white transition-all\" data-kid=\"114\">\n                                    <i class=\"ph-bold ph-steering-wheel text-2xl\" data-kid=\"115\"></i>\n                                </div>\n                                <div data-kid=\"116\">\n                                    <h3 class=\"font-heading font-black text-xl text-[#0F172A] tracking-tighter uppercase\" data-kid=\"117\">Flota y choferes</h3>\n                                    <p class=\"text-[11px] text-[#0F172A]/60 mt-1 font-bold tracking-tight uppercase\" data-kid=\"118\">Asignación de activos disponibles.</p>\n                                </div>\n                            </div>\n                            <div class=\"flex items-center gap-12\" data-kid=\"119\">\n                                <div class=\"flex items-center gap-2 text-[#0F172A]\" data-kid=\"120\">\n                                    <span class=\"text-[10px] font-black uppercase tracking-[0.2em]\" data-kid=\"121\">02 ACTIVOS</span>\n                                </div>\n                                <i class=\"ph-bold ph-arrow-right text-[#0F172A]/20 group-hover:text-[#0F172A] transition-all group-hover:translate-x-2\" data-kid=\"122\"></i>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n\n                \n                <aside class=\"col-span-4 flex flex-col gap-12 reveal-item\" data-kid=\"123\">\n                    \n                    \n                    <div class=\"bg-white border-2 border-[#0F172A] p-8 flex flex-col gap-8 relative\" data-kid=\"124\">\n                        \n                        <div class=\"absolute top-0 left-0 right-0 h-1.5 bg-[var(--color-accent)]\" data-kid=\"125\"></div>\n                        <h2 class=\"text-[11px] font-black uppercase tracking-[0.4em] text-[#0F172A]\" data-kid=\"126\">Estado de preparación</h2>\n                        <div class=\"border-2 border-[#0F172A] p-6 flex flex-col gap-6\" data-kid=\"127\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"128\">\n                                <div class=\"w-10 h-10 bg-[#0F172A] text-white flex items-center justify-center\" data-kid=\"129\">\n                                    <i class=\"ph-bold ph-check\" data-kid=\"130\"></i>\n                                </div>\n                                <h4 class=\"font-heading font-black text-[#0F172A] text-xl tracking-tight uppercase\" data-kid=\"131\">Datos listos</h4>\n                            </div>\n                            <p class=\"text-xs text-[#0F172A] font-bold leading-relaxed uppercase tracking-wide\" data-kid=\"132\">\n                                Parámetros de geolocalización, disponibilidad de flota y demanda validados al 100%.\n                            </p>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"bg-white p-10 outline-offset-accent flex flex-col items-center justify-center text-center gap-8 rounded-none\" data-kid=\"133\">\n                        <h2 class=\"text-[11px] font-black uppercase tracking-[0.4em] text-[#0F172A] w-full text-left\" data-kid=\"134\">Siguiente ruta</h2>\n                        <div class=\"w-24 h-24 border-2 border-[#0F172A] flex items-center justify-center\" data-kid=\"135\">\n                            <i class=\"ph-bold ph-calendar-blank text-5xl text-[#0F172A]/20\" data-kid=\"136\"></i>\n                        </div>\n                        <div class=\"flex flex-col gap-2\" data-kid=\"137\">\n                            <p class=\"font-heading font-black text-xl text-[#0F172A] tracking-tighter uppercase\" data-kid=\"138\">Sin programación</p>\n                            <p class=\"text-[10px] text-[#0F172A]/40 px-6 font-bold uppercase tracking-widest\" data-kid=\"139\">Cola de despacho vacía.</p>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"bg-white border-2 border-[#0F172A] p-8 flex flex-col gap-8 relative overflow-hidden\" data-kid=\"140\">\n                        <div class=\"flex items-center justify-between\" data-kid=\"141\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"142\">\n                                <i class=\"ph-bold ph-database text-3xl text-[var(--color-accent)]\" data-kid=\"143\"></i>\n                                <h3 class=\"font-heading font-black text-sm tracking-[0.3em] uppercase\" data-kid=\"144\">Security</h3>\n                            </div>\n                        </div>\n                        <div class=\"flex flex-col gap-2\" data-kid=\"145\">\n                            <p class=\"text-[10px] text-[#0F172A]/40 uppercase font-black tracking-widest\" data-kid=\"146\">Backup Status</p>\n                            <p class=\"text-xl font-black text-[#0F172A] tracking-tighter uppercase\" data-kid=\"147\">Sin respaldo registrado</p>\n                        </div>\n                        <button class=\"w-full bg-[#0F172A] text-white py-5 text-[10px] font-black tracking-[0.3em] uppercase hover:bg-[var(--color-accent)] transition-all\" data-kid=\"148\">\n                            EJECUTAR BACKUP\n                        </button>\n                    </div>\n\n                </aside>\n            </div>\n\n        </div>\n    </main>\n\n    \n    <script src=\"https://unpkg.com/@phosphor-icons/web\" data-kid=\"149\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"150\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"151\"></script>\n    \n    <script data-kid=\"152\">\n        gsap.registerPlugin(ScrollTrigger);\n\n        // Sidebar Navigation Active Indicator Animation (#motion-nav-indicator-slide)\n        const navItems = document.querySelectorAll('.nav-link');\n        const activeBar = document.querySelector('#nav-active-bar');\n\n        function moveIndicator(index) {\n            const item = navItems[index];\n            const top = item.offsetTop;\n            const height = item.offsetHeight;\n            \n            gsap.to(activeBar, {\n                y: top,\n                height: height,\n                duration: 0.4,\n                ease: \"power3.out\"\n            });\n        }\n\n        navItems.forEach((item, index) => {\n            item.addEventListener('mouseenter', () => moveIndicator(index));\n            // Return to first item (active) if needed, here we just follow hover\n        });\n\n        // Entrance reveals (#gsap-mask-wipe style)\n        gsap.from(\".reveal-item\", {\n            duration: 1.2,\n            opacity: 0,\n            y: 40,\n            stagger: 0.2,\n            ease: \"expo.out\",\n            clearProps: \"all\"\n        });\n\n        // Stats Count Up Animation (#motion-inview-count-up)\n        document.querySelectorAll('.stat-value').forEach(stat => {\n            const target = parseInt(stat.getAttribute('data-target'));\n            \n            ScrollTrigger.create({\n                trigger: stat,\n                start: \"top 90%\",\n                onEnter: () => {\n                    gsap.to(stat, {\n                        innerText: target,\n                        duration: 2,\n                        snap: { innerText: 1 },\n                        ease: \"power2.out\"\n                    });\n                }\n            });\n        });\n\n        // Mask wipe effect for headings\n        document.querySelectorAll('h1').forEach(heading => {\n            gsap.fromTo(heading, \n                { clipPath: \"inset(0 100% 0 0)\" }, \n                { clipPath: \"inset(0 0 0 0)\", duration: 1.5, ease: \"power4.inOut\" }\n            );\n        });\n\n    </script>\n</div>\n",
