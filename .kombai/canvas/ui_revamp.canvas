    "var_a64f0f98f56b": {
      "type": "variant",
      "label": "Industrial Fleet (Dashboard)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 1380,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap');\n\n:root {\n  --bg: #F4F0EC;\n  --panel: #1B1B1B;\n  --accent: #F04A00;\n  --ready: #D1E231;\n  --border-thick: 3px;\n  --shadow-color: #1B1B1B;\n}\n\nbody {\n  font-family: 'Fira Sans', sans-serif;\n  background-color: var(--bg);\n  color: var(--panel);\n  margin: 0;\n  padding: 0;\n  overflow-x: clip;\n}\n\n.font-heading {\n  font-family: 'Space Grotesk', sans-serif;\n}\n\n.brutalist-border {\n  border: var(--border-thick) solid var(--panel);\n}\n\n.hard-offset {\n  box-shadow: 6px 6px 0 var(--shadow-color);\n}\n\n.hard-offset-sm {\n  box-shadow: 4px 4px 0 var(--shadow-color);\n}\n\n.washi-tape {\n  position: absolute;\n  top: -12px;\n  left: 20px;\n  height: 24px;\n  width: 100px;\n  background-color: rgba(209, 226, 49, 0.6);\n  transform: rotate(-1.5deg);\n  z-index: 10;\n  pointer-events: none;\n}\n\n.notch-tag {\n  clip-path: polygon(10% 0%, 100% 0%, 100% 100%, 10% 100%, 0% 50%);\n}\n\n.stitched {\n  position: relative;\n}\n.stitched::after {\n  content: \"\";\n  position: absolute;\n  top: 4px;\n  left: 4px;\n  right: 4px;\n  bottom: 4px;\n  border: 1px dashed var(--panel);\n  opacity: 0.2;\n  pointer-events: none;\n}\n\n/* Scrollbar styling */\n::-webkit-scrollbar {\n  width: 12px;\n}\n::-webkit-scrollbar-track {\n  background: var(--bg);\n  border-left: 2px solid var(--panel);\n}\n::-webkit-scrollbar-thumb {\n  background: var(--panel);\n  border: 2px solid var(--bg);\n}\n\n.sidebar-item-active {\n  background-color: var(--bg);\n  color: var(--panel);\n  box-shadow: 4px 4px 0 var(--accent);\n  border: var(--border-thick) solid var(--panel);\n}\n\n/* Animations will be handled by GSAP/Motion */\n</style>\n\n<div class=\"min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <nav class=\"w-full bg-white brutalist-border border-t-0 border-l-0 border-r-0 flex justify-between items-center px-8 py-4 z-40 relative\" data-kid=\"2\">\n    <div class=\"flex items-center gap-12\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--accent)] brutalist-border flex items-center justify-center motion-pop\" data-kid=\"5\">\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checked-shield.svg\" class=\"w-6 h-6 invert\" alt=\"Logo\" decoding=\"async\" loading=\"lazy\" data-kid=\"6\">\n        </div>\n        <div class=\"flex flex-col\" data-kid=\"7\">\n           <span class=\"font-heading font-black text-xl tracking-tighter uppercase leading-none\" data-kid=\"8\">BAMX <span class=\"text-[var(--accent)]\" data-kid=\"9\">PLANNER</span></span>\n           <span class=\"text-[10px] uppercase font-bold tracking-[0.2em] opacity-40\" data-kid=\"10\">Rutas y entregas</span>\n        </div>\n      </div>\n      <div class=\"hidden lg:flex gap-8 font-heading font-bold uppercase text-xs tracking-widest\" data-kid=\"11\">\n        <a href=\"#\" class=\"relative px-2 py-1 bg-[var(--accent)]/10 text-[var(--accent)] brutalist-border border-[var(--accent)]/20\" data-kid=\"12\">Tablero</a>\n        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity py-1\" data-kid=\"13\">Flota</a>\n        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity py-1\" data-kid=\"14\">Colonias</a>\n      </div>\n    </div>\n    \n    <div class=\"flex items-center gap-8\" data-kid=\"15\">\n      <div class=\"hidden md:flex gap-6 font-heading font-bold uppercase text-xs tracking-widest\" data-kid=\"16\">\n        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"17\">Historial</a>\n        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"18\">Reportes</a>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"19\">\n        <div class=\"w-10 h-10 brutalist-border flex items-center justify-center bg-white cursor-pointer hover:bg-[var(--bg)] transition-colors\" data-kid=\"20\">\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/checklist.svg\" class=\"w-5 h-5\" alt=\"Alerts\" decoding=\"async\" loading=\"lazy\" data-kid=\"21\">\n        </div>\n        <button class=\"bg-[var(--accent)] text-white px-6 py-2.5 font-heading font-black brutalist-border hard-offset-sm uppercase text-sm tracking-tighter motion-pop transition-shadow\" data-kid=\"22\">\n          GENERAR PLANEACIÓN\n        </button>\n      </div>\n    </div>\n  </nav>\n\n  <div class=\"flex flex-1\" data-kid=\"23\">\n    \n    <aside class=\"w-72 bg-[var(--panel)] text-[var(--bg)] flex flex-col p-8 gap-10 sticky top-0 h-[calc(100vh-80px)] overflow-y-auto z-30\" data-kid=\"24\">\n      <div class=\"flex flex-col gap-2\" data-kid=\"25\">\n        <span class=\"text-[10px] uppercase font-heading font-black tracking-widest text-[var(--bg)]/40\" data-kid=\"26\">Operador Activo</span>\n        <div class=\"flex items-center gap-4 p-4 bg-white/5 brutalist-border border-white/10\" data-kid=\"27\">\n          <div class=\"relative\" data-kid=\"28\">\n            <img src=\"https://i.pravatar.cc/150?u=logistics_pro\" class=\"w-12 h-12 border-2 border-[var(--ready)] object-cover\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"29\">\n            <div class=\"absolute -bottom-1 -right-1 w-4 h-4 bg-[var(--ready)] border-2 border-[var(--panel)] rounded-full\" data-kid=\"30\"></div>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"31\">\n            <span class=\"font-heading font-bold text-sm leading-tight uppercase\" data-kid=\"32\">J. González</span>\n            <span class=\"text-[10px] text-[var(--accent)] font-bold uppercase tracking-tighter\" data-kid=\"33\">Turno Matutino</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex flex-col gap-6\" data-kid=\"34\">\n        <nav class=\"flex flex-col gap-3\" data-kid=\"35\">\n          <span class=\"text-[10px] uppercase font-heading font-black tracking-widest text-[var(--bg)]/40 mb-1\" data-kid=\"36\">Menú Navegación</span>\n          <a href=\"#\" class=\"nav-item-animate sidebar-item-active flex items-center gap-3 px-4 py-3 font-heading font-black uppercase text-sm tracking-tight hover:translate-x-1\" data-kid=\"37\">\n             <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/confirmed.svg\" class=\"w-5 h-5\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"38\">\n             Inicio\n          </a>\n          <a href=\"#\" class=\"nav-item-animate flex items-center gap-3 px-4 py-3 opacity-50 hover:opacity-100 font-heading font-black uppercase text-sm tracking-tight hover:translate-x-1\" data-kid=\"39\">\n             <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/level-crossing.svg\" class=\"w-5 h-5 invert\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n             Planeación\n          </a>\n          <a href=\"#\" class=\"nav-item-animate flex items-center gap-3 px-4 py-3 opacity-50 hover:opacity-100 font-heading font-black uppercase text-sm tracking-tight hover:translate-x-1\" data-kid=\"41\">\n             <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/tally-mark-5.svg\" class=\"w-5 h-5 invert\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"42\">\n             Historial\n          </a>\n          \n          <div class=\"nav-item-animate h-px bg-white/10 my-4\" data-kid=\"43\"></div>\n          <span class=\"nav-item-animate text-[10px] uppercase font-heading font-black tracking-widest text-[var(--bg)]/40 mb-1\" data-kid=\"44\">Datos de Operación</span>\n          \n          <div class=\"grid grid-cols-1 gap-1\" data-kid=\"45\">\n            <a href=\"#\" class=\"nav-item-animate flex items-center justify-between px-4 py-2.5 opacity-60 hover:opacity-100 hover:bg-white/5 group\" data-kid=\"46\">\n              <span class=\"text-[11px] uppercase font-black tracking-widest\" data-kid=\"47\">Colonias</span>\n              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-3 h-3 invert opacity-0 group-hover:opacity-100 transition-opacity\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"48\">\n            </a>\n            <a href=\"#\" class=\"nav-item-animate flex items-center justify-between px-4 py-2.5 opacity-60 hover:opacity-100 hover:bg-white/5 group\" data-kid=\"49\">\n              <span class=\"text-[11px] uppercase font-black tracking-widest\" data-kid=\"50\">Instituciones</span>\n              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-3 h-3 invert opacity-0 group-hover:opacity-100 transition-opacity\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"51\">\n            </a>\n            <a href=\"#\" class=\"nav-item-animate flex items-center justify-between px-4 py-2.5 opacity-60 hover:opacity-100 hover:bg-white/5 group\" data-kid=\"52\">\n              <span class=\"text-[11px] uppercase font-black tracking-widest\" data-kid=\"53\">Supermercados</span>\n              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-3 h-3 invert opacity-0 group-hover:opacity-100 transition-opacity\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"54\">\n            </a>\n            <a href=\"#\" class=\"nav-item-animate flex items-center justify-between px-4 py-2.5 opacity-60 hover:opacity-100 hover:bg-white/5 group\" data-kid=\"55\">\n              <span class=\"text-[11px] uppercase font-black tracking-widest\" data-kid=\"56\">Caridad</span>\n              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-3 h-3 invert opacity-0 group-hover:opacity-100 transition-opacity\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"57\">\n            </a>\n            <a href=\"#\" class=\"nav-item-animate flex items-center justify-between px-4 py-2.5 opacity-60 hover:opacity-100 hover:bg-white/5 group\" data-kid=\"58\">\n              <span class=\"text-[11px] uppercase font-black tracking-widest\" data-kid=\"59\">Unidades</span>\n              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-3 h-3 invert opacity-0 group-hover:opacity-100 transition-opacity\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"60\">\n            </a>\n            <a href=\"#\" class=\"nav-item-animate flex items-center justify-between px-4 py-2.5 opacity-60 hover:opacity-100 hover:bg-white/5 group\" data-kid=\"61\">\n              <span class=\"text-[11px] uppercase font-black tracking-widest\" data-kid=\"62\">Choferes</span>\n              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-3 h-3 invert opacity-0 group-hover:opacity-100 transition-opacity\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"63\">\n            </a>\n          </div>\n        </nav>\n      </div>\n\n      <div class=\"mt-auto flex flex-col gap-4\" data-kid=\"64\">\n        <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 opacity-50 hover:opacity-100 font-heading font-black uppercase text-sm tracking-tight transition-all\" data-kid=\"65\">\n           <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/camargue-cross.svg\" class=\"w-5 h-5 invert\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"66\">\n           Ajustes\n        </a>\n        <div class=\"p-4 bg-white/5 border-2 border-white/10 stitched\" data-kid=\"67\">\n           <div class=\"flex items-center justify-between mb-2\" data-kid=\"68\">\n             <span class=\"text-[9px] uppercase font-black opacity-40\" data-kid=\"69\">System Core 4.2</span>\n             <div class=\"w-2 h-2 rounded-full bg-[var(--ready)] shadow-[0_0_8px_var(--ready)]\" data-kid=\"70\"></div>\n           </div>\n           <div class=\"text-[10px] font-mono opacity-60 truncate\" data-kid=\"71\">NOD_SRV_EST_01 // 200 OK</div>\n        </div>\n      </div>\n    </aside>\n\n    \n    <main class=\"flex-1 p-10 overflow-x-clip bg-[var(--bg)] relative\" data-kid=\"72\">\n       \n       <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: radial-gradient(var(--panel) 1px, transparent 1px); background-size: 32px 32px;\" data-kid=\"73\"></div>\n\n       <div class=\"max-w-7xl mx-auto space-y-12 relative z-10\" data-kid=\"74\">\n          \n          \n          <header class=\"flex flex-col lg:flex-row lg:items-end justify-between gap-8 stagger-reveal py-4\" data-kid=\"75\">\n             <div class=\"space-y-6\" data-kid=\"76\">\n                <div class=\"inline-block bg-[var(--accent)] text-white px-4 py-1.5 text-xs font-black uppercase brutalist-border tracking-widest motion-pop\" data-kid=\"77\">Buenos días, Operación</div>\n                <h1 class=\"text-7xl font-heading font-black uppercase leading-[0.8] tracking-tighter\" data-kid=\"78\">Panel de<br data-kid=\"79\"><span class=\"text-[var(--accent)]\" data-kid=\"80\">Operación</span></h1>\n                <p class=\"text-xl max-w-2xl font-medium opacity-60 leading-snug\" data-kid=\"81\">Revisa lo importante, genera rutas y deja listo lo que se enviará a los conductores en el turno de hoy.</p>\n             </div>\n             <div class=\"flex items-stretch gap-4\" data-kid=\"82\">\n                <button class=\"bg-white brutalist-border w-[72px] flex items-center justify-center hard-offset hover:bg-[var(--bg)] transition-colors active:translate-x-[2px] active:translate-y-[2px] active:shadow-none motion-pop\" data-kid=\"83\">\n                   <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/tick.svg\" class=\"w-8 h-8\" alt=\"Check\" decoding=\"async\" loading=\"lazy\" data-kid=\"84\">\n                </button>\n                <button class=\"bg-[var(--panel)] text-white px-10 py-5 font-heading font-black brutalist-border hard-offset uppercase text-lg tracking-tighter hover:translate-y-[-2px] transition-shadow active:translate-y-[2px] motion-pop\" data-kid=\"85\">\n                   RESPALDAR DATOS\n                </button>\n             </div>\n          </header>\n\n          \n          <div class=\"grid grid-cols-12 gap-10\" data-kid=\"86\">\n            \n            \n            <div class=\"col-span-12 lg:col-span-8 space-y-12\" data-kid=\"87\">\n               \n               \n               <div class=\"grid grid-cols-5 grid-rows-2 gap-6 h-[420px]\" data-kid=\"88\">\n                  \n                  <div class=\"col-span-3 row-span-2 brutalist-border bg-[var(--panel)] text-white p-10 relative overflow-hidden flex flex-col justify-between motion-pop\" data-kid=\"89\">\n                     <div class=\"washi-tape\" data-kid=\"90\"></div>\n                     <div class=\"relative z-10\" data-kid=\"91\">\n                        <span class=\"text-[var(--accent)] font-heading font-black uppercase tracking-tighter text-sm mb-3 block\" data-kid=\"92\">Acción Crítica</span>\n                        <h2 class=\"text-5xl font-heading font-black uppercase leading-none\" data-kid=\"93\">Generar<br data-kid=\"94\">Planeación</h2>\n                        <div class=\"mt-4 flex gap-2\" data-kid=\"95\">\n                           <div class=\"px-2 py-1 bg-white/10 text-[9px] font-black uppercase tracking-widest border border-white/20\" data-kid=\"96\">Auto-Optimized</div>\n                           <div class=\"px-2 py-1 bg-[var(--ready)] text-[var(--panel)] text-[9px] font-black uppercase tracking-widest\" data-kid=\"97\">Ready for deployment</div>\n                        </div>\n                     </div>\n                     <div class=\"relative z-10 flex items-center justify-between\" data-kid=\"98\">\n                        <p class=\"max-w-xs text-sm font-medium opacity-60 leading-snug\" data-kid=\"99\">Optimiza las rutas de hoy basándote en los 67 puntos de recolección disponibles en almacén central.</p>\n                        <button class=\"bg-[var(--accent)] text-white p-8 brutalist-border hard-offset hover:scale-105 transition-transform\" data-kid=\"100\">\n                           <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/crossed-axes.svg\" class=\"w-10 h-10 invert\" alt=\"Optimize\" decoding=\"async\" loading=\"lazy\" data-kid=\"101\">\n                        </button>\n                     </div>\n                     \n                     <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/camargue-cross.svg\" class=\"absolute -right-20 -bottom-20 w-[400px] h-[400px] invert opacity-[0.03] pointer-events-none\" alt=\"Deco\" decoding=\"async\" loading=\"lazy\" data-kid=\"102\">\n                  </div>\n\n                  \n                  <div class=\"col-span-1 row-span-1 brutalist-border bg-white p-5 flex flex-col justify-between motion-pop\" data-kid=\"103\">\n                     <div class=\"flex justify-between items-start\" data-kid=\"104\">\n                        <div class=\"flex flex-col gap-1\" data-kid=\"105\">\n                           <span class=\"text-[10px] font-heading font-black uppercase opacity-40 leading-none\" data-kid=\"106\">Rutas</span>\n                           <div class=\"h-[2px] w-6 bg-[var(--accent)]\" data-kid=\"107\"></div>\n                        </div>\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/level-crossing.svg\" class=\"w-5 h-5 opacity-30\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"108\">\n                     </div>\n                     <span class=\"text-6xl font-heading font-black leading-none tracking-tighter\" data-kid=\"109\">0</span>\n                  </div>\n\n                  <div class=\"col-span-1 row-span-1 brutalist-border bg-white p-5 flex flex-col justify-between motion-pop\" data-kid=\"110\">\n                     <div class=\"flex justify-between items-start\" data-kid=\"111\">\n                        <div class=\"flex flex-col gap-1\" data-kid=\"112\">\n                           <span class=\"text-[10px] font-heading font-black uppercase opacity-40 leading-none\" data-kid=\"113\">Puntos</span>\n                           <div class=\"h-[2px] w-6 bg-[var(--panel)]\" data-kid=\"114\"></div>\n                        </div>\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/confirmed.svg\" class=\"w-5 h-5 opacity-30\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"115\">\n                     </div>\n                     <span class=\"text-6xl font-heading font-black leading-none tracking-tighter\" data-kid=\"116\">67</span>\n                  </div>\n\n                  <div class=\"col-span-1 row-span-1 brutalist-border bg-[var(--ready)] p-5 flex flex-col justify-between motion-pop\" data-kid=\"117\">\n                     <div class=\"flex justify-between items-start\" data-kid=\"118\">\n                        <div class=\"flex flex-col gap-1\" data-kid=\"119\">\n                           <span class=\"text-[10px] font-heading font-black uppercase opacity-60 leading-none\" data-kid=\"120\">Unidades</span>\n                           <div class=\"h-[2px] w-6 bg-[var(--panel)]\" data-kid=\"121\"></div>\n                        </div>\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/camargue-cross.svg\" class=\"w-5 h-5 opacity-30\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"122\">\n                     </div>\n                     <span class=\"text-6xl font-heading font-black leading-none tracking-tighter\" data-kid=\"123\">2</span>\n                  </div>\n\n                  <div class=\"col-span-1 row-span-1 brutalist-border bg-white p-5 flex flex-col justify-between motion-pop\" data-kid=\"124\">\n                     <div class=\"flex justify-between items-start\" data-kid=\"125\">\n                        <div class=\"flex flex-col gap-1\" data-kid=\"126\">\n                           <span class=\"text-[10px] font-heading font-black uppercase opacity-40 leading-none\" data-kid=\"127\">Choferes</span>\n                           <div class=\"h-[2px] w-6 bg-[var(--panel)]\" data-kid=\"128\"></div>\n                        </div>\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/thumb-up.svg\" class=\"w-5 h-5 opacity-30\" alt=\"Icon\" decoding=\"async\" loading=\"lazy\" data-kid=\"129\">\n                     </div>\n                     <span class=\"text-6xl font-heading font-black leading-none tracking-tighter\" data-kid=\"130\">2</span>\n                  </div>\n               </div>\n\n               \n               <section class=\"space-y-6\" data-kid=\"131\">\n                  <div class=\"flex items-center justify-between border-b-4 border-[var(--panel)] pb-4\" data-kid=\"132\">\n                     <div class=\"flex items-center gap-4\" data-kid=\"133\">\n                        <h3 class=\"text-4xl font-heading font-black uppercase\" data-kid=\"134\">Trabajo Pendiente</h3>\n                        <div class=\"px-2 py-1 bg-[var(--panel)] text-white text-[10px] font-black uppercase tracking-widest\" data-kid=\"135\">3 Items</div>\n                     </div>\n                     <p class=\"text-xs font-bold opacity-40 uppercase tracking-widest\" data-kid=\"136\">Ordenado por prioridad</p>\n                  </div>\n\n                  <div class=\"grid grid-cols-1 gap-4\" id=\"task-list\" data-kid=\"137\">\n                     \n                     <div class=\"task-item bg-white brutalist-border p-6 flex items-center justify-between relative hard-offset hover:translate-x-1 hover:bg-gray-50/50\" data-kid=\"138\">\n                        <div class=\"stitched absolute inset-0 pointer-events-none\" data-kid=\"139\"></div>\n                        <div class=\"flex items-center gap-8 relative z-10\" data-kid=\"140\">\n                           <div class=\"w-8 h-8 brutalist-border flex items-center justify-center bg-white cursor-pointer hover:bg-[var(--ready)] group\" data-kid=\"141\">\n                              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/check-mark.svg\" class=\"w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity\" alt=\"Check\" decoding=\"async\" loading=\"lazy\" data-kid=\"142\">\n                           </div>\n                           <div class=\"flex flex-col\" data-kid=\"143\">\n                              <h4 class=\"font-heading font-bold text-xl uppercase tracking-tight\" data-kid=\"144\">Preparar planeación mensual</h4>\n                              <p class=\"text-sm font-medium opacity-50\" data-kid=\"145\">Genera, revisa y guarda las rutas del periodo actual de distribución.</p>\n                           </div>\n                        </div>\n                        <div class=\"flex items-center gap-6 relative z-10\" data-kid=\"146\">\n                           <div class=\"notch-tag bg-[var(--accent)] text-white px-5 py-1.5 font-heading font-black text-[10px] uppercase\" data-kid=\"147\">Prioritario</div>\n                           <button class=\"w-12 h-12 brutalist-border flex items-center justify-center hover:bg-[var(--bg)] transition-colors\" data-kid=\"148\">\n                              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-6 h-6 rotate-45\" alt=\"Action\" decoding=\"async\" loading=\"lazy\" data-kid=\"149\">\n                           </button>\n                        </div>\n                     </div>\n\n                     \n                     <div class=\"task-item bg-white brutalist-border p-6 flex items-center justify-between relative hard-offset hover:translate-x-1 hover:bg-gray-50/50\" data-kid=\"150\">\n                        <div class=\"stitched absolute inset-0 pointer-events-none\" data-kid=\"151\"></div>\n                        <div class=\"flex items-center gap-8 relative z-10\" data-kid=\"152\">\n                           <div class=\"w-8 h-8 brutalist-border flex items-center justify-center bg-[var(--ready)]\" data-kid=\"153\">\n                              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/check-mark.svg\" class=\"w-4 h-4\" alt=\"Check\" decoding=\"async\" loading=\"lazy\" data-kid=\"154\">\n                           </div>\n                           <div class=\"flex flex-col\" data-kid=\"155\">\n                              <h4 class=\"font-heading font-bold text-xl uppercase tracking-tight\" data-kid=\"156\">Ubicaciones listas</h4>\n                              <p class=\"text-sm font-medium opacity-50\" data-kid=\"157\">Las coordenadas geográficas permiten calcular rutas logísticas eficientes.</p>\n                           </div>\n                        </div>\n                        <div class=\"flex items-center gap-6 relative z-10\" data-kid=\"158\">\n                           <button class=\"w-12 h-12 brutalist-border flex items-center justify-center hover:bg-[var(--bg)] transition-colors\" data-kid=\"159\">\n                              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-6 h-6 rotate-45\" alt=\"Action\" decoding=\"async\" loading=\"lazy\" data-kid=\"160\">\n                           </button>\n                        </div>\n                     </div>\n\n                     \n                     <div class=\"task-item bg-white brutalist-border p-6 flex items-center justify-between relative hard-offset hover:translate-x-1 hover:bg-gray-50/50\" data-kid=\"161\">\n                        <div class=\"stitched absolute inset-0 pointer-events-none\" data-kid=\"162\"></div>\n                        <div class=\"flex items-center gap-8 relative z-10\" data-kid=\"163\">\n                           <div class=\"w-8 h-8 brutalist-border flex items-center justify-center bg-white cursor-pointer hover:bg-[var(--ready)] group\" data-kid=\"164\">\n                              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/check-mark.svg\" class=\"w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity\" alt=\"Check\" decoding=\"async\" loading=\"lazy\" data-kid=\"165\">\n                           </div>\n                           <div class=\"flex flex-col\" data-kid=\"166\">\n                              <h4 class=\"font-heading font-bold text-xl uppercase tracking-tight\" data-kid=\"167\">Flota y choferes</h4>\n                              <p class=\"text-sm font-medium opacity-50\" data-kid=\"168\">Recursos humanos y mecánicos listos para ser asignados a rutas.</p>\n                           </div>\n                        </div>\n                        <div class=\"flex items-center gap-6 relative z-10\" data-kid=\"169\">\n                           <button class=\"w-12 h-12 brutalist-border flex items-center justify-center hover:bg-[var(--bg)] transition-colors\" data-kid=\"170\">\n                              <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-6 h-6 rotate-45\" alt=\"Action\" decoding=\"async\" loading=\"lazy\" data-kid=\"171\">\n                           </button>\n                        </div>\n                     </div>\n                  </div>\n               </section>\n            </div>\n\n            \n            <div class=\"col-span-12 lg:col-span-4 space-y-10\" data-kid=\"172\">\n               \n               \n               <div class=\"bg-white brutalist-border p-8 hard-offset space-y-8 relative motion-pop\" data-kid=\"173\">\n                  <div class=\"flex items-center justify-between border-b-2 border-[var(--panel)] pb-4\" data-kid=\"174\">\n                     <h4 class=\"font-heading font-black uppercase text-2xl tracking-tight\" data-kid=\"175\">Estado para<br data-kid=\"176\">Planear</h4>\n                     <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checked-shield.svg\" class=\"w-8 h-8\" alt=\"Shield\" decoding=\"async\" loading=\"lazy\" data-kid=\"177\">\n                  </div>\n                  \n                  <div class=\"p-6 bg-[var(--ready)]/10 border-2 border-dashed border-[var(--panel)] relative\" data-kid=\"178\">\n                     <div class=\"inline-block bg-[var(--ready)] border-2 border-[var(--panel)] px-3 py-1 text-[10px] font-black uppercase mb-4 motion-pop\" data-kid=\"179\">DATOS LISTOS</div>\n                     <p class=\"text-sm font-medium opacity-80 leading-snug\" data-kid=\"180\">Puedes generar la planeación mensual ahora mismo. Todos los datos de inventario y puntos de recolección están validados.</p>\n                  </div>\n\n                  <div class=\"space-y-4\" data-kid=\"181\">\n                     <div class=\"flex items-center justify-between\" data-kid=\"182\">\n                        <span class=\"text-[10px] font-heading font-black uppercase opacity-40 tracking-widest\" data-kid=\"183\">Siguiente ruta</span>\n                        <div class=\"h-[2px] w-20 bg-[var(--panel)]/10\" data-kid=\"184\"></div>\n                     </div>\n                     <div class=\"h-28 brutalist-border border-dashed flex flex-col items-center justify-center opacity-40 text-center p-6 bg-[var(--bg)]/50\" data-kid=\"185\">\n                        <p class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"186\">No hay rutas pendientes</p>\n                     </div>\n                  </div>\n\n                  <button class=\"w-full flex items-center justify-center gap-4 p-6 brutalist-border bg-[var(--panel)] text-white font-heading font-black uppercase text-sm hard-offset hover:bg-[var(--panel)]/90 transition-all active:translate-x-[2px] active:translate-y-[2px] active:shadow-none group\" data-kid=\"187\">\n                     <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-6 h-6 invert group-hover:rotate-90 transition-transform duration-500\" alt=\"Respaldo\" decoding=\"async\" loading=\"lazy\" data-kid=\"188\">\n                     Respaldo Recomendado\n                  </button>\n                  \n                  <div class=\"flex items-center gap-2 pt-2\" data-kid=\"189\">\n                     <div class=\"w-2 h-2 rounded-full bg-[var(--ready)] animate-pulse\" data-kid=\"190\"></div>\n                     <span class=\"text-[9px] font-mono opacity-40 uppercase\" data-kid=\"191\">Último respaldo hace 12 min.</span>\n                  </div>\n               </div>\n\n               \n               <div class=\"bg-[var(--accent)] text-white brutalist-border p-8 hard-offset relative overflow-hidden motion-pop group\" data-kid=\"192\">\n                  <h5 class=\"text-3xl font-heading font-black uppercase leading-none mb-4 relative z-10\" data-kid=\"193\">Asistencia<br data-kid=\"194\">Logística</h5>\n                  <p class=\"text-sm opacity-95 mb-6 relative z-10 font-medium leading-tight\" data-kid=\"195\">¿Dudas con la asignación? Consulta el manual de operaciones BAMX v2.4.</p>\n                  <a href=\"#\" class=\"inline-flex items-center gap-3 text-xs font-black uppercase border-b-4 border-white pb-1 relative z-10 hover:gap-5 transition-all\" data-kid=\"196\">\n                     Abrir Guía de Usuario\n                     <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-4 h-4 invert group-hover:rotate-180 transition-transform duration-700\" alt=\"Arrow\" decoding=\"async\" loading=\"lazy\" data-kid=\"197\">\n                  </a>\n                  \n                  <div class=\"absolute -right-6 -bottom-6 w-40 h-40 bg-white/10 brutalist-border border-white/20 rotate-12 pointer-events-none flex items-center justify-center\" data-kid=\"198\">\n                      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-flare.svg\" class=\"w-20 h-20 invert opacity-40\" alt=\"motif\" data-kid=\"199\">\n                  </div>\n               </div>\n\n            </div>\n          </div>\n       </div>\n    </main>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"200\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"201\"></script>\n<script data-kid=\"202\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  window.addEventListener('load', () => {\n    // GSAP Entrance Animations\n    gsap.from(\".stagger-reveal\", {\n      autoAlpha: 0,\n      y: 30,\n      duration: 1,\n      ease: \"power4.out\",\n      stagger: 0.2\n    });\n\n    // Task items sliding in from side\n    gsap.from(\".task-item\", {\n      autoAlpha: 0,\n      x: 50,\n      duration: 0.8,\n      ease: \"back.out(1.7)\",\n      stagger: 0.15,\n      scrollTrigger: {\n        trigger: \"#task-list\",\n        start: \"top 80%\",\n      }\n    });\n\n    // Sidebar items entrance\n    gsap.from(\".nav-item-animate\", {\n      autoAlpha: 0,\n      x: -20,\n      duration: 0.5,\n      stagger: 0.02,\n      ease: \"power3.out\"\n    });\n  });\n</script>\n\n<script type=\"module\" data-kid=\"203\">\n  import { animate, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  // Motion.js for the springy pops\n  animate(\".motion-pop\", \n    { scale: [0.8, 1], opacity: [0, 1] }, \n    { \n      type: \"spring\", \n      visualDuration: 0.6, \n      bounce: 0.4,\n      delay: stagger(0.1)\n    }\n  );\n\n  // Additional micro-interactions\n  document.querySelectorAll('.brutalist-border').forEach(el => {\n    el.addEventListener('mouseenter', () => {\n      animate(el, { y: -2 }, { duration: 0.2 });\n    });\n    el.addEventListener('mouseleave', () => {\n      animate(el, { y: 0 }, { duration: 0.2 });\n    });\n  });\n</script>\n",
